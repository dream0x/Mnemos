# Copy this file to .env and fill in real values.
# NEVER commit .env to git. The .gitignore already excludes it.

# --- Kimi (Moonshot AI) — Kimi Track requirement ---
# Get a key at https://platform.kimi.ai/console/api-keys
KIMI_API_KEY=sk-replace-me
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# --- fal.ai (FLUX image generation) ---
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=replace-me

# --- Pinata (IPFS hosting for NFT card images + metadata) ---
# Get a JWT at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=replace-me

# --- Telegram bot ---
# Create the bot via @BotFather, copy the HTTP API token here
TELEGRAM_BOT_TOKEN=000000:replace-me
# Your own numeric Telegram user ID (unlimited usage / mint enabled).
# Get it by messaging @userinfobot
OWNER_TELEGRAM_ID=000000000
# Optional: comma-separated list of trusted user IDs (20 readings/day, no mint)
ALLOWED_TELEGRAM_IDS=

# --- Public-mode rate limits (env-tunable) ---
# Per-day quota for unknown public users
PUBLIC_DAILY_READINGS=3
# Lifetime quota for unknown public users (anti-abuse)
PUBLIC_LIFETIME_READINGS=10
# Per-day quota for ALLOWED_TELEGRAM_IDS
ALLOWLIST_DAILY_READINGS=20
# Hard global daily ceiling in USD; bot stops serving non-owners when hit
MAX_DAILY_USD_SPEND=5
# Master kill switch for non-owner traffic
PUBLIC_ENABLED=true

# --- Base Sepolia (testnet NFT mint) ---
# Free RPC: use Alchemy at https://dashboard.alchemy.com/ (Base Sepolia)
BASE_SEPOLIA_RPC=https://sepolia.base.org
# Deployer wallet PRIVATE KEY — testnet only, dedicated wallet, NEVER mainnet funds
# Generate with: cast wallet new
DEPLOYER_PRIVATE_KEY=0xreplace-me
# Address where the OracleCard ERC-721 lives (set after `forge create`)
ORACLE_CARD_CONTRACT=0x0000000000000000000000000000000000000000

# --- Viewer (GitHub Pages) ---
# After enabling GitHub Pages from /docs, set this to your Pages URL.
VIEWER_BASE_URL=https://dream0x.github.io/Mnemos/

# --- Misc ---
LOG_LEVEL=INFO
